@model List<HospitalVeterinario.Data.Models.Nomina>

<div class="container py-4">
    <h2>Mis Sueldos</h2>

    <table class="table table-striped table-bordered text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Mes/Año</th>
                <th>Tipo</th>
                <th>Base</th>
                <th>Horas Extras</th>
                <th>Pago H. Extras</th>
                <th>IGSS</th>
                <th>ISR</th>
                <th>Neto</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FechaPago.ToShortDateString()</td>
                    <td>@item.Mes/@item.Anio</td>
                    <td>@item.TipoPago</td>

                    <td>Q @item.SalarioBase.ToString("0.00")</td>

                    <td>@item.HorasExtras.ToString("0.00")</td>
                    <td>Q @item.MontoHorasExtras.ToString("0.00")</td>

                    <td>Q @item.DescuentoIGSS.ToString("0.00")</td>
                    <td>Q @item.DescuentoISR.ToString("0.00")</td>

                    <td><strong>Q @item.SalarioNeto.ToString("0.00")</strong></td>
                </tr>
            }
        </tbody>
    </table>
</div>