@model List<HospitalVeterinario.Data.Models.Vacacion>

<h2 class="fw-bold mb-4">Historial de mis Vacaciones</h2>

@if (Model.Any(v => v.Estado == "Aprobada"))
{
    <div class="alert alert-success">
        ✅ Tenés vacaciones aprobadas. Tus días pendientes ya fueron actualizados.
    </div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Fecha solicitud</th>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Días</th>
            <th>Motivo</th>
            <th>Estado</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                <td>@item.DiasSolicitados</td>
                <td>@item.Motivo</td>
                <td>
                    @if (item.Estado == "Aprobada")
                    {
                        <span class="badge bg-success">Aprobada</span>
                    }
                    else if (item.Estado == "Rechazada")
                    {
                        <span class="badge bg-danger">Rechazada</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>