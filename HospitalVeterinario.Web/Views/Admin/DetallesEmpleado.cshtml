@model HospitalVeterinario.Data.Models.Empleado

@{
    ViewData["Title"] = "Detalles del Empleado";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-3">Detalles del Empleado</h2>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h5 class="fw-bold mb-3">Datos personales</h5>

            <p><strong>Nombre:</strong> @Model.Nombre</p>
            <p><strong>Apellido:</strong> @Model.Apellido</p>
            <p><strong>Fecha de nacimiento:</strong> @Model.FechaNacimiento?.ToString("dd/MM/yyyy")</p>
            <p><strong>Género:</strong> @Model.Genero</p>

            <hr />

            <h5 class="fw-bold mb-3">Contacto</h5>

            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Teléfono:</strong> @Model.Telefono</p>

            <hr />

            <h5 class="fw-bold mb-3">Documentos</h5>

            <p><strong>DPI:</strong> @Model.DPI</p>
            <p><strong>NIT:</strong> @Model.NIT</p>

            <hr />
            <h5 class="fw-bold mb-3">Datos laborales</h5>

            <p><strong>Fecha de contratación:</strong> @Model.FechaContratacion?.ToString("dd/MM/yyyy")</p>
            <p><strong>Estado:</strong> @(Model.EstadoEmpleado ?? "No registrado")</p>
            <p><strong>Departamento:</strong> @ViewBag.NombreDepartamento</p>
            <p><strong>Puesto:</strong> @ViewBag.NombrePuesto</p>

            <hr />

            <h5 class="fw-bold mb-3">Salario</h5>

            <p>
                <strong>Salario Base:</strong>
                @(Model.SalarioBase.HasValue ? "Q " + Model.SalarioBase.Value.ToString("N2") : "No registrado")
            </p>

            <p>
                <strong>Bonificación Decreto:</strong>
                @(Model.BonificacionDecreto.HasValue ? "Q " + Model.BonificacionDecreto.Value.ToString("N2") : "No registrado")
            </p>

            <hr />

            <h5 class="fw-bold mb-3">Datos bancarios</h5>

            <p><strong>Banco:</strong> @(Model.NombreBanco ?? "No registrado")</p>
            <p><strong>Número de cuenta:</strong> @(Model.NumeroCuentaBancaria ?? "No registrado")</p>
            <p><strong>Tipo de cuenta:</strong> @(Model.TipoCuentaBancaria ?? "No registrado")</p>

            <hr />

            <h5 class="fw-bold mb-3">IGSS</h5>

            <p><strong>Número IGSS:</strong> @(Model.NumeroIGSS ?? "No registrado")</p>

        </div>
    </div>

    <div class="mt-3">
        <a asp-action="EditarEmpleado" asp-route-id="@Model.IdEmpleado" class="btn btn-warning">
            Editar
        </a>
        <a href="/Admin/ListaEmpleados" class="btn btn-secondary">
             Volver
        </a>
       
    </div>

</div>