@model IEnumerable<HospitalVeterinario.Data.Models.Nomina>

@{
    ViewData["Title"] = "Flujo de Pagos";
}

<div class="container mt-4">

    <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary mt-3">
        ← Regresar al menú
    </a>

    <h4 class="mb-3">Flujo de Pagos</h4>

    <!-- 🔎 FILTRO -->
    <form method="get" asp-controller="Admin" asp-action="FlujoPagos" class="row g-3 mb-4">
        <div class="col-md-5">
            <label class="form-label fw-bold">Buscar por empleado</label>
            <input type="text" name="nombre" value="@ViewBag.Nombre"
                   class="form-control" placeholder="Ejemplo: Sabino Roman" />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Año</label>
            <input type="number" name="anio" value="@ViewBag.Anio"
                   class="form-control" placeholder="2026" />
        </div>

        <div class="col-md-4 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary btn-sm">Buscar</button>
            <a href="/Admin/FlujoPagos" class="btn btn-secondary btn-sm">Limpiar</a>
        </div>
    </form>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- 📊 TABLA -->
    <table class="table table-sm table-bordered table-hover text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Acción</th>
                <th>Fecha</th>
                <th>Empleado</th>
                <th>Mes/Año</th>
                <th>Tipo</th>
                <th>Base</th>
                <th>Horas</th>
                <th>H. Extras</th>
                <th>Bono 14</th>
                <th>Aguinaldo</th>
                <th>IGSS</th>
                <th>ISR</th>
                <th>Ausencias</th>
                <th>Séptimo</th>
                <th>Neto</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var pago in Model)
            {
                <tr>
                    <td>
                        <form action="/Admin/EliminarPago" method="post"
                              onsubmit="return confirm('¿Eliminar pago?');">
                            <input type="hidden" name="id" value="@pago.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">X</button>
                        </form>
                    </td>

                    <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                    <td>@pago.Empleado?.Nombre @pago.Empleado?.Apellido</td>
                    <td>@pago.Mes/@pago.Anio</td>
                    <td>@pago.TipoPago</td>

                    <td>Q @pago.SalarioBase.ToString("0.00")</td>

                    <!-- 🔥 HORAS EXTRAS -->
                    <td>@pago.HorasExtras.ToString("0.00")</td>
                    <td>Q @pago.MontoHorasExtras.ToString("0.00")</td>

                    <!-- BONO 14 -->
                    <td>
                        @if (pago.Mes == 7 && pago.Bono14 > 0)
                        {
                            <span class="badge bg-success">
                                Q @pago.Bono14.ToString("0.00")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <!-- AGUINALDO -->
                    <td>
                        @if (pago.Mes == 12 && pago.Aguinaldo > 0)
                        {
                            <span class="badge bg-primary">
                                Q @pago.Aguinaldo.ToString("0.00")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <td>Q @pago.DescuentoIGSS.ToString("0.00")</td>
                    <td>Q @pago.DescuentoISR.ToString("0.00")</td>
                    <td>Q @pago.DescuentoAusencias.ToString("0.00")</td>
                    <td>Q @pago.DescuentoSeptimo.ToString("0.00")</td>

                    <td><strong>Q @pago.SalarioNeto.ToString("0.00")</strong></td>
                </tr>
            }
        </tbody>
    </table>
</div>