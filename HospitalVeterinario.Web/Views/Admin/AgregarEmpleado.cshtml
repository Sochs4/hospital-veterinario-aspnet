@model HospitalVeterinario.Data.Models.Empleado

@{
    ViewData["Title"] = "Agregar Empleado";
}


<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="fw-bold">Lista de Empleados</h1>

    <a href="@Url.Action("Index", "Admin")" class="btn btn-secondary mt-3">
        ← Regresar al menú
    </a>
</div>

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <h2 class="fw-bold mb-1">Agregar Empleado</h2>
            <p class="text-muted mb-4">Registrar nuevo empleado en Recursos Humanos.</p>

            <form action="/Admin/AgregarEmpleado" method="post">

                <h5 class="fw-bold mb-3">Datos personales</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre</label>
                        <input name="Nombre" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Apellido</label>
                        <input name="Apellido" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha de nacimiento</label>
                        <input name="FechaNacimiento" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Género</label>
                        <select name="Genero" class="form-select">
                            <option value="">Seleccione</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                        </select>
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Contacto</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input name="Email" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input name="Telefono" class="form-control" />
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Documentos</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">DPI</label>
                        <input name="DPI" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">NIT</label>
                        <input name="NIT" class="form-control" />
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Datos laborales</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha de contratación</label>
                        <input name="FechaContratacion" type="date" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Estado</label>
                        <select name="EstadoEmpleado" class="form-select">
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Departamento</label>
                        <select name="IdDepartamento" id="IdDepartamento" class="form-select">
                            <option value="">Seleccione</option>
                            @foreach (var d in ViewBag.Departamentos)
                            {
                                <option value="@d.IdDepartamento">@d.NombreDepartamento</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Puesto</label>
                        <select name="IdPuesto" id="IdPuesto" class="form-select">
                            <option value="">Seleccione</option>
                            @foreach (var p in ViewBag.Puestos)
                            {
                                <option value="@p.IdPuesto"
                                        data-depto="@p.IdDepartamento"
                                        data-salario="@p.SalarioBase">
                                    @p.NombrePuesto
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Salario</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Salario base</label>
                        <input name="SalarioBase" id="SalarioBase" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Bonificación Decreto</label>
                        <input name="BonificacionDecreto" class="form-control" value="250" readonly />
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3">Datos bancarios</h5>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Banco</label>
                        <input name="NombreBanco" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Número de cuenta</label>
                        <input name="NumeroCuentaBancaria" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tipo de cuenta</label>
                        <input name="TipoCuentaBancaria" class="form-control" />
                    </div>
                </div>

                <h5 class="fw-bold mt-4 mb-3">IGSS</h5>

                <div class="mb-3">
                    <label class="form-label">Número IGSS</label>
                    <input name="NumeroIGSS" class="form-control" />
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        Guardar empleado
                    </button>

                    <a href="/Admin/ListaEmpleados" class="btn btn-secondary">
                        Volver
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    const departamento = document.getElementById("IdDepartamento");
    const puesto = document.getElementById("IdPuesto");
    const salario = document.getElementById("SalarioBase");

    departamento.addEventListener("change", function () {
        const idDepartamento = this.value;

        puesto.value = "";
        salario.value = "";

        for (let option of puesto.options) {
            if (option.value === "") {
                option.style.display = "block";
                continue;
            }

            option.style.display =
                option.getAttribute("data-depto") === idDepartamento
                    ? "block"
                    : "none";
        }
    });

    puesto.addEventListener("change", function () {
        const option = this.options[this.selectedIndex];
        salario.value = option.getAttribute("data-salario") || "";
    });
</script>