@{
    var rol = Context.Session.GetString("Rol");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Veterinaria KOA</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #ff7e5f, #f7971e, #6a11cb);
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: rgba(25, 25, 35, 0.95);
            color: white;
            padding: 25px 18px;
            box-shadow: 8px 0 25px rgba(0,0,0,0.25);
            animation: slideSidebar .7s ease-out;
        }

            .sidebar h3 {
                font-weight: bold;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: white;
                text-decoration: none;
                padding: 12px 15px;
                border-radius: 15px;
                margin-bottom: 8px;
                transition: .3s;
            }

                .sidebar a:hover {
                    background: linear-gradient(135deg, #6a11cb, #ff7e5f);
                    transform: translateX(6px);
                }

        .content {
            margin-left: 260px;
            padding: 30px;
            animation: fadeContent .8s ease-out;
        }

        .topbar {
            background: rgba(255,255,255,0.92);
            border-radius: 22px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.18);
        }

        .page-container {
            background: rgba(255,255,255,0.92);
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.18);
        }

        .btn-koa {
            border: none;
            color: white;
            border-radius: 25px;
            background: linear-gradient(135deg, #6a11cb, #ff7e5f);
            padding: 9px 18px;
            font-weight: 600;
        }

            .btn-koa:hover {
                color: white;
                transform: scale(1.04);
            }

        @@keyframes slideSidebar {
            from {
                opacity: 0;
                transform: translateX(-60px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes fadeContent {
            from {
                opacity: 0;
                transform: translateY(25px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <h3>Veterinaria KOA</h3>

        @if (rol == "Admin")
        {
            <a href="/Admin/Index">Dashboard</a>
            <a href="/Admin/ListaEmpleados">Empleados</a>
            <a href="/Admin/AgregarEmpleado">Agregar empleado</a>
            <a href="/Admin/Usuarios">Usuarios</a>
            <a href="/Admin/SeleccionarEmpleadoPago">Pagar empleados</a>
            <a href="/Admin/FlujoPagos">Flujo de pagos</a>
            <a href="/Admin/ProductividadEmpleado">Productividad</a>
            <a href="/Admin/SolicitudesVacaciones">Solicitudes vacaciones</a>
            <a href="/Admin/DespedirEmpleado" class="btn btn-outline-danger">
                Despedir empleado
            </a>

            <a href="/Login/CerrarSesion">Cerrar sesión</a>
        }
        else if (rol == "Empleado")
        {
            <a href="/Trabajador/Index">Mi Dashboard</a>
            <a href="/Trabajador/Perfil">Mi Perfil</a>
            <a href="/Trabajador/MisPagos">Mis Sueldos</a>
            <a href="/Trabajador/MiProductividad">Mi Productividad</a>
            <a href="/Trabajador/SolicitarVacaciones">Solicitar Vacaciones</a>
            <a href="/Trabajador/HistorialVacaciones">Historial vacaciones</a>
            <a href="/Login/CerrarSesion">Cerrar sesión</a>
        }
    </div>

    <div class="content">
        <div class="topbar d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold mb-0">Sistema de Recursos Humanos</h4>
                <small class="text-muted">Veterinaria KOA</small>
            </div>
        </div>

        <div class="page-container">
            @RenderBody()
        </div>
    </div>

    @RenderSection("Scripts", required: false)

</body>
</html>